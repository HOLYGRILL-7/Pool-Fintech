{
  "expo": {
    "name": "Pool",
    "slug": "Pool",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pool",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A1628",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.bismarkjones.Pool"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EBF5FB",
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "android": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#EBF5FB"
          },
          "ios": {
            "image": "./assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#EBF5FB"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
